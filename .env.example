# Camera credentials (REQUIRED — no defaults)
CAMERA_IP=192.168.1.100
CAMERA_USERNAME=admin
CAMERA_PASSWORD=changeme
# Or provide the full RTSP URL directly:
# CAMERA_RTSP_URL=rtsp://admin:changeme@192.168.1.100:554/Streaming/Channels/101

# Detection settings
CONFIDENCE_THRESHOLD=0.5
GENDER_THRESHOLD=0.6
GENDER_ENABLED=true
YOLO_MODEL=yolov8n.pt

# Streaming
STREAM_FPS=10
JPEG_QUALITY=65

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Timezone
TZ=Asia/Kuala_Lumpur

# Security — set a strong random key to protect API endpoints (for programmatic access)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Login credentials — set ADMIN_PASSWORD to enable login-based dashboard access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Session secret — auto-generated if not set (set for persistence across restarts)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
# Session expiry in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# CORS — comma-separated allowed origins (empty = same-origin only)
# CORS_ORIGINS=https://dashboard.example.com,https://admin.example.com

# Embedding encryption — set to encrypt face embeddings at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMBEDDING_ENCRYPTION_KEY=

# Logging
LOG_FILE=logs/visitor-stat.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
