# Camera Configuration
CAMERA_IP=192.168.1.100
CAMERA_USERNAME=admin
CAMERA_PASSWORD=your_password_here
CAMERA_RTSP_URL=rtsp://admin:your_password_here@192.168.1.100:554/Streaming/Channels/102

# Detection Settings
CONFIDENCE_THRESHOLD=0.5
GENDER_THRESHOLD=0.6
GENDER_ENABLED=true
YOLO_MODEL=yolov8n.pt

# Streaming
STREAM_FPS=15
JPEG_QUALITY=65

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Timezone
TZ=Asia/Kuala_Lumpur
